    "@vitest/coverage-v8": "^4.0.0",
    "autoprefixer": "^10.4.27",
    "dotenv": "^17.2.3",
    "jsdom": "^27.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
